# foreground = #c5c9c7
# cursor-color = #c5c9c7
# selection-background = #24262D
# selection-foreground = #c5c9c7
# general
theme = "tokyonight"
# theme = "Everforest Dark - Hard"
# theme = "Kanagawa Dragon"
shell-integration = zsh
confirm-close-surface = false
background-opacity = 0.9
background-blur-radius = 20
copy-on-select = clipboard
# cursor-invert-fg-bg = true

# fonts
# font-family =
# font-family = "Source Code Pro"
font-family = "Berkeley Mono Variable"
font-feature = ss02
# font-family = "SF Mono"
# font-family = "Dank Mono"
# font-family = "Inconsolata Regular"
# font-family = "Maple Mono NL"
# font-feature = cv35
# font-family = "Iosevka Term Extended"
# font-family = "IBM Plex Mono"
font-family = "Symbols Nerd Font"
font-size = 14
font-thicken = true
font-thicken-strength = 0
adjust-cell-height = -1
# adjust-cell-width = 1


# window
# window-padding-y = 0
# window-padding-x = 10
window-padding-balance = true
window-step-resize = true
window-theme = dark
window-title-font-family = "SF Mono"
window-colorspace = display-p3
scrollbar = "never"

# macos
macos-option-as-alt = true
macos-titlebar-style = tabs
macos-icon = custom-style
macos-icon-frame = aluminum
macos-icon-screen-color = #1a1b26
macos-icon-ghost-color = #a4daff

# splits
unfocused-split-opacity = 0.85
keybind = ctrl+\=new_split:right
keybind = ctrl+minus=new_split:down

# navigation
keybind = ctrl+shift+l=goto_split:right
keybind = ctrl+shift+h=goto_split:left
keybind = ctrl+shift+j=goto_split:bottom
keybind = ctrl+shift+k=goto_split:top

# shaders
# custom-shader = "/Users/alex/dev/ghostty-shaders/glitchy.glsl"
# custom-shader-animation = true
